{
  "name": "harvest-cli",
  "version": "0.1.0",
  "description": "Bulk download article listings as Markdown with generic AdapterSpecs and optional browser-session support.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taisei-ide-0123/harvest.git",
