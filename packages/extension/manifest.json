{
  "manifest_version": 3,
  "name": "harvest Bridge",
  "version": "0.1.0",
  "description": "Connects the harvest CLI to the current browser tab.",
  "permissions": ["activeTab", "alarms", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "harvest Bridge",
    "default_popup": "src/popup.html"
  }
}
