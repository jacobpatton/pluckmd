{
  "manifest_version": 3,
  "name": "pluckmd Bridge",
  "version": "0.1.0",
  "description": "Connects the pluckmd CLI to the current browser tab.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "alarms", "scripting", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "pluckmd Bridge",
    "default_popup": "src/popup.html"
  }
}
